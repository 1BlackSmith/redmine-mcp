{
  "name": "@pavelsmith/redmine-mcp",
  "version": "0.1.3",
  "description": "Generic Redmine MCP provider for REST API access from Codex, OpenCode, and other MCP clients.",
  "type": "module",
  "main": "./src/server.js",
  "exports": {
    ".": "./src/server.js"
  },
  "bin": {
    "redmine-mcp": "./src/server.js"
  },
  "files": [
    "src",
    "examples",
    "README.md"
  ],
  "scripts": {
    "start": "node ./src/server.js",
    "test": "node --test test/actions.test.js test/load-env-file.test.js",
    "test:e2e": "node --test test/redmine.e2e.test.js",
    "test:e2e:docker": "REDMINE_TEST_ENV_FILE=.env.test.docker node --test test/redmine.e2e.test.js",
    "redmine:test:up": "bash scripts/redmine-test-up.sh",
    "redmine:test:down": "docker compose -f docker-compose.redmine-test.yml down",
    "redmine:test:reset": "docker compose -f docker-compose.redmine-test.yml down -v",
    "check": "node --check ./src/server.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "redmine",
    "codex",
    "opencode"
  ],
  "license": "MIT"
}
